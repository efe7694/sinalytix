# Sinalytix API — Environment Variables
# Copy to .env and fill in real values. Never commit .env!

# App
APP_NAME=Sinalytix API
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://sinalytix:sinalytix@localhost:5432/sinalytix

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth / JWT — CHANGE IN PRODUCTION
JWT_SECRET_KEY=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# PHI Encryption — CHANGE IN PRODUCTION
PHI_ENCRYPTION_KEY=dev-32-byte-key-change-in-prod!!

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# AI Service
AI_SERVICE_URL=http://localhost:8001

# OTP
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10
OTP_MAX_SENDS_PER_WINDOW=3

# OAuth — required before production
# Apple: bundle ID from App Store Connect
APPLE_BUNDLE_ID=com.sinalytix.patient
# Google: web client ID from Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=<web-client-id>

# SMS provider — wire one in auth_service.otp_send()
# Option A: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Option B: AWS SNS
AWS_SNS_REGION=ca-central-1
