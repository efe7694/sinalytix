# Same distinct database as packages/db (see DEVIATIONS.md D2).
DATABASE_URL=postgresql://sinalytix:sinalytix@localhost:5432/sinalytix_core
REDIS_URL=redis://localhost:6379

PORT=8080

# HS256 signing secret for 15-min access tokens (Module 2 §1.2). Rotate via a
# real secrets manager in prod (Module 3 §8) — env var is a local-dev stand-in.
JWT_ACCESS_SECRET=dev-only-change-me-jwt-access-secret

# AES-256-GCM key (32 raw bytes, base64) standing in for KMS column-encryption
# (Module 1 §1.6) on totp_secrets.secret_encrypted until real KMS is wired up.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COLUMN_ENCRYPTION_KEY=

# HCP app bundle/client identifiers id_token audience checks are validated against.
APPLE_BUNDLE_ID=ca.sinalytix.patient
GOOGLE_CLIENT_ID=

# Non-owner app role (Module 3 §1.3 — RLS only actually applies to a
# non-owner role; see migration 0007_app-role.js + DEVIATIONS.md D7).
APP_DATABASE_URL=postgresql://sinalytix_app:CHANGEME@localhost:5432/sinalytix_core
