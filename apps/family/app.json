{
  "expo": {
    "name": "Sinalytix Family",
    "slug": "sinalytix-family",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "sinalytix-family",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sinalytix.family",
      "infoPlist": {
        "NSCameraUsageDescription": "Sinalytix, QR kodu okuyabilmek için kameranıza erişmesi gerekmektedir.",
        "NSFaceIDUsageDescription": "Sinalytix, güvenli girişiniz için Face ID kullanmaktadır."
      },
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.sinalytix.family",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-apple-authentication"],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1",
          "sounds": []
        }
      ],
      "expo-localization",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:8000",
      "googleIosClientId": "",
      "googleAndroidClientId": "",
      "googleWebClientId": ""
    }
  }
}
